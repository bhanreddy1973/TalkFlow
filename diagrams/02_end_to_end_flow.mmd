    style APPPRESS fill:#e8f5e9
    style RECLAYER fill:#fce4ec
    style AUDIOCB fill:#fce4ec
    style HKRELEASE fill:#fff3e0
    style APPRELEASE fill:#e8f5e9
    style STOPREC fill:#fce4ec
    style TRANSCRIBETHREAD fill:#e8f5e9
    style WHISPER fill:#e3f2fd
    style POSTPROCESS fill:#e8f5e9
    style INSERTION fill:#f3e5f5
    style FINISH fill:#e8f5e9